# Copy this file to .env.deploy and replace the placeholder values before
# starting the full-stack compose deployment.

JWT_SECRET=replace_with_strong_jwt_secret
APP_USER=replace_with_app_username
APP_PASS_HASH=replace_with_bcrypt_password_hash
GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
